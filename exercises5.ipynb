   "source": [
    "def rotate_right(lst, k):\n",
    "    k = k % len(lst)\n",
    "    return lst[-k:] + lst[:-k]\n",
    "\n",
    "print(rotate_right([1, 2, 3, 4, 5], 2))"
   ]
  }
