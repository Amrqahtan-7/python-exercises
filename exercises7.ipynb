   "source": [
    "def manual_iteration(lst):\n",
    "    it = iter(lst)\n",
    "    while True:\n",
    "        try:\n",
    "            print(next(it))\n",
    "        except StopIteration:\n",
    "            print(\"End of iteration\")\n",
    "            break\n",
    "\n",
    "manual_iteration([10, 20, 30])"
   ]
  }
 ],
