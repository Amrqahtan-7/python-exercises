    "# Q1\n",
    "\n",
    "def reverse_string(s):\n",
    "    return s[::-1]\n",
    "\n",
    "def every_second_char(s):\n",
    "    return s[::2]\n",
    "\n",
    "print(reverse_string(\"hello\"))\n",
    "print(every_second_char(\"hello\"))"
   ]
